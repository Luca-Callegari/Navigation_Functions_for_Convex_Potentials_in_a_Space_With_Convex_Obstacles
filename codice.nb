Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"tf", "=", "100"}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Definisco", " ", "la", " ", "lunghezza", " ", "del", " ", "passo", " ", 
    RowBox[{"(", "costante", ")"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"l", "=", "0.05"}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Voglio", " ", "intervalli", " ", "di", " ", "integrali", " ", "tutti", 
    " ", "uguali", " ", "e", " ", "interi"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"passi", "=", 
    RowBox[{"Floor", "[", 
     RowBox[{"tf", "/", "l"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"MetodoEulero", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"gradX_", ",", "gradY_"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"x0_", ",", "y0_"}], "}"}], ",", "passi_", ",", "l_"}], "]"}], 
    ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"punto", "=", 
         RowBox[{"{", 
          RowBox[{"x0", ",", "y0"}], "}"}]}], ",", "i", ",", "dx", ",", "dy", 
        ",", "fx", ",", "fy", ",", "nuovoPunto", ",", "traj"}], "}"}], ",", 
      "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{"traj", "=", 
        RowBox[{
         RowBox[{"Reap", "[", "\[IndentingNewLine]", "        ", 
          RowBox[{"For", "[", 
           RowBox[{
            RowBox[{"i", "=", "1"}], ",", 
            RowBox[{"i", "<=", "passi"}], ",", 
            RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", "\t ", 
            RowBox[{
             RowBox[{"fx", "=", 
              RowBox[{"gradX", "@@", "punto"}]}], ";", "\[IndentingNewLine]", 
             "          ", 
             RowBox[{"fy", "=", 
              RowBox[{"gradY", "@@", "punto"}]}], ";", "\[IndentingNewLine]", 
             "\t ", 
             RowBox[{"(*", 
              RowBox[{
               RowBox[{"Print", "[", 
                RowBox[{
                "\"\<Passo \>\"", ",", "i", ",", "\"\<: punto=\>\"", ",", 
                 "punto", ",", "\"\<, grad= \>\"", ",", 
                 RowBox[{"{", 
                  RowBox[{"fx", ",", "fy"}], "}"}]}], "]"}], ";"}], "*)"}], 
             "\[IndentingNewLine]", "\t", 
             RowBox[{"(*", 
              RowBox[{
              "Direzione", " ", "nuovo", " ", "punto", " ", "normalizzato", 
               " ", 
               RowBox[{"(", 
                RowBox[{
                "cos\[IGrave]", " ", "rispetto", " ", "il", " ", "numero", 
                 " ", "dei", " ", "passi"}], ")"}]}], "*)"}], 
             "\[IndentingNewLine]", "\t", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"dx", ",", "dy"}], "}"}], "=", 
              RowBox[{"l", "*", 
               RowBox[{"Normalize", "[", 
                RowBox[{"{", 
                 RowBox[{"fx", ",", "fy"}], "}"}], "]"}]}]}], ";", 
             "\[IndentingNewLine]", "\t", 
             RowBox[{"nuovoPunto", "=", 
              RowBox[{"punto", "+", 
               RowBox[{"{", 
                RowBox[{"dx", ",", "dy"}], "}"}]}]}], ";", " ", 
             RowBox[{"(*", 
              RowBox[{"Passo", " ", "al", " ", "punto", " ", "successivo"}], 
              "*)"}], "\[IndentingNewLine]", "\t", 
             RowBox[{"punto", "=", "nuovoPunto"}], ";", "\[IndentingNewLine]",
              "\[IndentingNewLine]", "\t", 
             RowBox[{"Sow", "[", "nuovoPunto", "]"}], ";"}]}], 
           "\[IndentingNewLine]", "\t", "]"}], "\[IndentingNewLine]", " ", 
          "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]",
        "\t", 
       RowBox[{"Return", "[", "traj", "]"}], ";"}]}], "\[IndentingNewLine]", 
     "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Siccome", " ", "phix", " ", "\[EGrave]", " ", "una", " ", "funzione", 
     " ", "del", " ", "tipo", " ", "phix", " ", "del", " ", "tipo", " ", "f", 
     RowBox[{"(", 
      RowBox[{"x", ",", "y"}], ")"}], " ", "ma", " ", "non", " ", "posso", 
     " ", "valutarla", " ", "la", " ", "phix", " ", "in", " ", "un", " ", 
     "punto"}], ",", " ", 
    RowBox[{
     RowBox[{
     "allora", " ", "\[IndentingNewLine]", "mi", " ", "serve", " ", "trovare",
       " ", "un", " ", "modo", " ", "per", " ", "tramutare", " ", "una", " ", 
      "phix"}], "=", 
     RowBox[{
      RowBox[{"f", 
       RowBox[{"(", 
        RowBox[{"x", ",", "y"}], ")"}], " ", "in", " ", "una", " ", 
       RowBox[{"phix", "[", 
        RowBox[{"x", ",", "y"}], "]"}]}], "=", 
      RowBox[{"f", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"x", ",", "y"}], ")"}], ".", "Un"}], " ", "modo", " ", "per",
        " ", "farlo", " ", "\[EGrave]", " ", "usare", " ", "la", " ", 
       RowBox[{"Function", "[", "]"}]}]}]}]}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PHIX", " ", "=", " ", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{"Evaluate", "[", "phix", "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PHIY", " ", "=", " ", 
    RowBox[{"Function", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}], ",", 
      RowBox[{"Evaluate", "[", "phiy", "]"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gradNeg", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", "y"}], "}"}], ",", 
        RowBox[{"-", 
         RowBox[{"PHIX", "[", 
          RowBox[{"x", ",", "y"}], "]"}]}]}], "]"}], ",", 
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", "y"}], "}"}], ",", 
        RowBox[{"-", 
         RowBox[{"PHIY", "[", 
          RowBox[{"x", ",", "y"}], "]"}]}]}], "]"}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", "\n", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"traj", "=", 
    RowBox[{"MetodoEulero", "[", 
     RowBox[{"gradNeg", ",", 
      RowBox[{"{", 
       RowBox[{"x0", ",", "y0"}], "}"}], ",", "passi", ",", "l"}], "]"}]}], 
   ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Metto", " ", "le", " ", "condizioni", " ", "iniziali", " ", 
    RowBox[{"all", "'"}], "inizio", " ", "della", " ", "traiettoria"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"traj", "=", 
    RowBox[{"Prepend", "[", 
     RowBox[{"traj", ",", 
      RowBox[{"{", 
       RowBox[{"x0", ",", "y0"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"PP", "=", 
    RowBox[{"ListLinePlot", "[", 
     RowBox[{"traj", ",", 
      RowBox[{"AspectRatio", "->", "1"}], ",", 
