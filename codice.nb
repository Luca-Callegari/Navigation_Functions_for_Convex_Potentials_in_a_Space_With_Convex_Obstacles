           RowBox[{"-", "dim"}], ",", "dim"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "dim"}], ",", "dim"}], "}"}]}], "}"}]}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"PP", ",", "start", ",", "OB", ",", 
   RowBox[{"PlotRange", "->", 
    RowBox[{"{", 
